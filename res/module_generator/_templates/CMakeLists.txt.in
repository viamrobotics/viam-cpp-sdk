
cmake_minimum_required(VERSION 3.25 FATAL_ERROR)

project({{ .ModuleName }}
    DESCRIPTION "Viam C++ {{ .ModuleName }} Module"
    LANGUAGES CXX
)

# Everything needs threads, and prefer -pthread if available
set(THREADS_PREFER_PTHREAD_FLAG ON)
find_package(Threads REQUIRED)

find_package(viam-cpp-sdk CONFIG REQUIRED COMPONENTS viamsdk)

add_executable({{ .ModuleName }}
    main.cpp
    src/{{ .ModelSnake }}.cpp
)

target_include_directories({{ .ModuleName }} PUBLIC src)

target_link_libraries({{ .ModuleName }}
    viam-cpp-sdk::viamsdk
)

install(
    FILES meta.json
    DESTINATION .
)

file(READ "${CMAKE_CURRENT_SOURCE_DIR}}/meta.json" _META_JSON)
string(JSON _FIRST_RUN ERROR_VARIABLE _FR_ERR GET "${_META_JSON}}" "first_run")
if(NOT _FR_ERR AND _FIRST_RUN AND EXISTS "${CMAKE_CURRENT_SOURCE_DIR}}/${_FIRST_RUN}}")
    install(FILES "${_FIRST_RUN}}" DESTINATION .)
endif()

install(TARGETS {{ .ModuleName }})

set(CPACK_PACKAGE_NAME "{{ .ModuleName }}")
set(CPACK_PACKAGE_FILE_NAME "module")
set(CPACK_GENERATOR "TGZ")
set(CPACK_INCLUDE_TOPLEVEL_DIRECTORY 0)
include(CPack)

